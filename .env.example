# ─────────────────────────────────────────────────────────────
## Ne jamais commiter des secrets reels dans `.env` (utiliser des placeholders).
# Base de données (PostgreSQL via Neon ou Supabase)
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/loyalty_db?sslmode=require"

# ─────────────────────────────────────────────────────────────
# JWT Auth
# ─────────────────────────────────────────────────────────────
JWT_SECRET="change-me-32-chars-minimum-random"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-32-chars-minimum-random-refresh"
JWT_REFRESH_EXPIRES_IN="30d"

# ─────────────────────────────────────────────────────────────
# API
# ─────────────────────────────────────────────────────────────
API_PORT=3001
API_HOST="0.0.0.0"
NODE_ENV="development"

# ─────────────────────────────────────────────────────────────
# Frontend (Next.js)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"

# ─────────────────────────────────────────────────────────────
# Storage (Cloudflare R2 — compatible S3)
# ─────────────────────────────────────────────────────────────
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET_NAME="loyalty-assets"
R2_PUBLIC_URL="https://your-bucket.r2.dev"

# ─────────────────────────────────────────────────────────────
# Queue (Redis via Upstash)
# ─────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
# Pour Upstash : redis://default:token@host.upstash.io:6379

# ─────────────────────────────────────────────────────────────
# IA — OpenAI Images API
# ─────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."

# ─────────────────────────────────────────────────────────────
# Google Wallet
# ─────────────────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL="wallet-sa@project.iam.gserviceaccount.com"
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n..."
GOOGLE_WALLET_ISSUER_ID="3388000000000000000"

# ─────────────────────────────────────────────────────────────
# Apple Wallet (PassKit)
# ─────────────────────────────────────────────────────────────
APPLE_PASS_TYPE_IDENTIFIER="pass.com.yourcompany.loyalty"
APPLE_TEAM_IDENTIFIER="ABCDE12345"
# Certificats chargés depuis le filesystem (hors repo !)
APPLE_SIGNER_CERT_PATH="/secrets/apple-pass-cert.pem"
APPLE_SIGNER_KEY_PATH="/secrets/apple-pass-key.pem"
APPLE_SIGNER_KEY_PASSPHRASE="your-key-passphrase"
APPLE_CERT_PATH="/secrets/apple-pass-cert.p12"
APPLE_CERT_PASSWORD="your-cert-password"
APPLE_WWDR_CERT_PATH="/secrets/apple-wwdr.pem"

# URL publique de l'API pour le web service Apple PassKit
APPLE_PASSKIT_WEB_SERVICE_URL="https://api.yourapp.com/api/v1/wallet/apple"

# ─────────────────────────────────────────────────────────────
# Stripe (facturation — activé après MVP)
# ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

