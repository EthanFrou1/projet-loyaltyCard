{
  "name": "fidelitepro-plus",
  "private": true,
  "version": "0.1.0",
  "description": "FidelitePro+ - plateforme de carte de fidelite digitale (Apple Wallet + Google Wallet)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:up && turbo run dev --filter=@loyalty/api --filter=@loyalty/web",
    "dev:up": "docker compose up -d postgres redis",
    "dev:down": "docker compose stop postgres redis",
    "dev:docker": "docker compose up -d",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:studio": "turbo run db:studio",
    "worker": "turbo run worker"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "prettier": "^3.3.0",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.0.0"
}
